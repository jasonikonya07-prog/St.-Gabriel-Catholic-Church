# St. Gabriel Catholic Church API environment example.
# Copy this file to backend/.env and replace every placeholder before production.
# Backend secrets must stay in backend/.env only. Never expose them through Vite or frontend code.

# Port where the Express backend listens locally.
PORT=5000

# Runtime mode. Use development locally and production on the live server.
NODE_ENV=development

# MySQL server host.
DB_HOST=localhost

# MySQL server port.
DB_PORT=3306

# MySQL database used by the church website.
DB_NAME=st_gabriel_church

# MySQL username.
DB_USER=root

# MySQL password. Use your real local or production database password in backend/.env.
DB_PASSWORD=your_mysql_password

# React frontend origins allowed by backend CORS. Use origins only, not page paths like /login.
# Add production domains as comma-separated origins, for example:
# CLIENT_URL=http://localhost:5173,https://stgabrielchurch.com
CLIENT_URL=http://localhost:5173

# Secret used to sign short-lived access JWTs for users and admins.
# Replace this with a long random value. Do not commit the real value.
JWT_ACCESS_SECRET=change_this_access_secret

# Secret reserved for refresh-token signing or cookie/session rotation.
# Use a different long random value from JWT_ACCESS_SECRET.
JWT_REFRESH_SECRET=change_this_refresh_secret

# Access token lifetime. Short lifetimes reduce damage if a token leaks.
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token lifetime. Keep this backend-only.
JWT_REFRESH_EXPIRES_IN=7d

# Initial admin display name used by npm run seed:admin.
ADMIN_NAME=Church Admin

# Initial admin email used by npm run seed:admin.
ADMIN_EMAIL=admin@stgabrielchurch.com

# Initial admin password used by npm run seed:admin.
# Replace this in backend/.env before seeding any real environment.
ADMIN_PASSWORD=ChangeThisStrongPassword

# SMTP host used by Nodemailer.
EMAIL_HOST=smtp.gmail.com

# SMTP port. Gmail commonly uses 587 for STARTTLS.
EMAIL_PORT=587

# SMTP account username.
EMAIL_USER=yourchurch@gmail.com

# SMTP password or app password. For Gmail, use an app password.
EMAIL_PASS=your_gmail_app_password

# Sender shown on outbound church emails.
EMAIL_FROM=St. Gabriel Catholic Church <yourchurch@gmail.com>

# General API rate-limit window length in minutes.
RATE_LIMIT_WINDOW_MINUTES=15

# Maximum total requests per IP during the general rate-limit window.
RATE_LIMIT_MAX_REQUESTS=300

# Maximum login/register attempts per IP during the rate-limit window.
LOGIN_RATE_LIMIT_MAX=5

# Maximum public form submissions per IP during the rate-limit window.
PUBLIC_FORM_RATE_LIMIT_MAX=20

# Whether Express should trust reverse proxy headers such as X-Forwarded-For.
# Keep false locally. Set true behind a trusted proxy/load balancer such as Vercel.
TRUST_PROXY=false
