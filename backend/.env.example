# St. Gabriel Church Backend Environment
# Copy this file to .env and replace placeholder values before running.

# Runtime
NODE_ENV=development
PORT=5000
API_PREFIX=/api
REQUEST_BODY_LIMIT=100kb
TRUST_PROXY=false

# MongoDB Atlas
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/st_gabriel_church?retryWrites=true&w=majority&authSource=admin&appName=Cluster0
MONGO_AUTO_INDEX=true
MONGO_MAX_POOL_SIZE=10
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000

# Frontend / CORS
CLIENT_URL=http://localhost:5173

# JWT / Cookies
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=8h
JWT_ACCESS_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=change-this-to-a-long-random-cookie-secret
REFRESH_COOKIE_SAMESITE=lax
REFRESH_COOKIE_SECURE=false

# Password hashing
BCRYPT_SALT_ROUNDS=12

# First admin seed
ADMIN_NAME=Church Admin
ADMIN_EMAIL=admin@stgabrielchurch.com
ADMIN_PASSWORD=ChangeThisStrongPassword

# Email / SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=yourchurch@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=St. Gabriel Church <yourchurch@gmail.com>
ADMIN_ALERT_EMAIL=admin@stgabrielchurch.com

# Rate limiting
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=300
LOGIN_RATE_LIMIT_MAX=5
PUBLIC_FORM_RATE_LIMIT_MAX=20
MPESA_RATE_LIMIT_MAX=10

# M-Pesa
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_mpesa_passkey
MPESA_CALLBACK_URL=https://your-backend.vercel.app/api/donations/mpesa/callback
