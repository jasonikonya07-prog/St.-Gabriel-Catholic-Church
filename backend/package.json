{
  "name": "st-gabriel-church-api",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Secure Express and MongoDB Atlas backend for St. Gabriel Church.",
  "engines": {
    "node": ">=20.19.0"
  },
  "main": "server.js",
  "scripts": {
    "build": "node --check server.js",
    "dev": "nodemon server.js",
    "start": "node server.js",
    "seed:admin": "node seeders/seedAdmin.js",
    "seed:settings": "node seeders/seedSettings.js",
    "maintenance:off": "node scripts/maintenanceMode.js off",
    "maintenance:on": "node scripts/maintenanceMode.js on",
    "maintenance:status": "node scripts/maintenanceMode.js status",
    "db:check": "node -e \"import('./config/db.js').then(async ({ connectDB, disconnectDB }) => { await connectDB(); await disconnectDB(); process.exit(0); }).catch((error) => { console.error(error); process.exit(1); })\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.2",
    "morgan": "^1.10.1",
    "nanoid": "^5.1.11",
    "nodemailer": "^8.0.8",
    "slugify": "^1.6.9",
    "xss": "^1.0.15",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
