# Public frontend API base URL used by Vite.
# This is safe for the browser because it is not a secret.
# Do not put JWT secrets, database credentials, SMTP passwords, or admin passwords in frontend env files.
# For Vercel production, set this to your deployed backend API URL, for example:
# VITE_API_URL=https://your-backend.example.com/api
VITE_API_URL=http://localhost:5000/api
