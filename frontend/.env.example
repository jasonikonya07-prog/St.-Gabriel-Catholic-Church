# Public frontend API base URL used by Vite.
# This is safe for the browser because it is not a secret.
# Do not put JWT secrets, database credentials, SMTP passwords, or admin passwords in frontend env files.
# If frontend and backend are deployed in the same Vercel project, this can be omitted.
# For a separate backend Vercel project, set this to the deployed backend URL ending in /api:
# VITE_API_URL=https://your-backend.vercel.app/api
VITE_API_URL=http://localhost:5000/api
